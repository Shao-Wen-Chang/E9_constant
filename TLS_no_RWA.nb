In[1]:=",ExpressionUUID->"3994b27d-ffe0-2c4d-9d23-551518105dcb"]
}, Open  ]],

Cell["\<\
Final population in the ground state as a function of \[Delta] and \
\[CapitalOmega] after a fixed evolution time . I\[CloseCurlyQuote]ll pick a \
few \[CapitalOmega]\[CloseCurlyQuote]s while treating \[Delta] as the \
variable. We see that\
\>", "Text",
 CellChangeTimes->{{3.972994921024618*^9, 3.9729949553595657`*^9}, {
   3.9729953582008533`*^9, 3.9729953830546455`*^9}, {3.9729955387841606`*^9, 
   3.9729955858434467`*^9}, {3.9729980638041306`*^9, 3.972998086289831*^9}, 
   3.9782072447901974`*^9},ExpressionUUID->"be8a325f-5fae-8746-8b09-\
ee2825b81735"],

Cell["\<\
it is at least roughly monotonic on either side of the minimum. Far off \
resonance it still looks somewhat like a sinc.\
\>", "Item",
 CellChangeTimes->{{3.972995593853878*^9, 3.972995599899502*^9}, {
  3.9729974410024643`*^9, 
  3.9729974533913383`*^9}},ExpressionUUID->"a6f76478-08a5-3e4a-b191-\
215415967059"],

Cell["\<\
it is almost at its minimum on resonance, although the quick-oscillating term \
broadens the feature a lot and shifts it, sometimes appreciably\
\>", "Item",
 CellChangeTimes->{{3.972995593853878*^9, 3.9729956487621517`*^9}, {
  3.9729979973717766`*^9, 3.9729979973727837`*^9}, {3.9782076562109966`*^9, 
  3.978207669674526*^9}},ExpressionUUID->"3fa64a84-0f1b-0848-9d13-\
eb6f0d82543c"],

Cell[CellGroupData[{

Cell["\<\
Longer and weaker modulation is better, if we can tolerate it - both better \
frequency resolution and less counter-rotating artifacts. In practice we are \
limited by hole dynamics.\
\>", "Item",
 CellChangeTimes->{{3.972995593853878*^9, 3.9729956487621517`*^9}, {
  3.972997998473091*^9, 3.9729980515293465`*^9}, {3.9729985562051735`*^9, 
  3.9729985672783546`*^9}},ExpressionUUID->"882ee6b6-a621-8a4c-8b74-\
b6b5d1f6f43f"],

