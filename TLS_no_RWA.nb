Cell[CellGroupData[{

Cell["Parametric numerical solutions", "Subsection",
 CellChangeTimes->{{3.9729890682561817`*^9, 
  3.9729890728079643`*^9}},ExpressionUUID->"faac6608-2ac8-4044-96bc-\
f77dbef2bb51"],

Cell["\<\
We therefore solve the equations without RWA numerically. We allow the \
parameters to be specified later.
I cannot \[OpenCurlyDoubleQuote]unpack\[CloseCurlyDoubleQuote] PrmnoRWA into \
c1 and c2, which makes sense. They probably have to be solved together.\
\>", "Text",
 CellChangeTimes->{{3.972989079214636*^9, 3.9729891418881264`*^9}, {
  3.9729892940673885`*^9, 3.9729893068565197`*^9}, {3.972989617073883*^9, 
  3.972989651752001*^9}},ExpressionUUID->"c5e0c51f-d506-3849-b1d5-\
a61d432ae387"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tMaxPrm", "=", "100"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"PrmSolnoRWA", "=", 
  RowBox[{"ParametricNDSolveValue", "[", 
   RowBox[{"\[DoubleStruckCapitalM]noRWA", ",", 
    RowBox[{"{", 
     RowBox[{"c1", ",", "c2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "tMaxPrm"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[CapitalOmega]", "\[Element]", "Reals"}], ",", 
      RowBox[{"\[Delta]", "\[Element]", "Reals"}]}], "}"}]}], 
   "]"}]}]}], "Input",
