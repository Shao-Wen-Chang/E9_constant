Cell["\<\
What we actually do is fix modulation time to be 1ms. Because we set \[Omega] \
= 1, this time is not a constant for different energy differences.\
\>", "Text",
 CellChangeTimes->{{3.978207583916525*^9, 3.9782075899578266`*^9}, {
   3.9782079384249573`*^9, 3.9782079857160225`*^9}, {3.9784876143405704`*^9, 
   3.9784876517820187`*^9}, {3.978487695634302*^9, 3.978487697079733*^9}, 
   3.9784882698432217`*^9},ExpressionUUID->"15c915c6-c3b5-004f-b76e-\
b37f49afed15"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tPM", "=", "1000"}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"in", " ", "ms", 
    RowBox[{"??", "?"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalOmega]max", "=", 
    RowBox[{"2", "*", "2", "*", "Pi"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"in", " ", "kHz"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"band14excitation", "[", "\[Omega]Gap_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t0", "=", 
       RowBox[{"tPM", "/", "\[Omega]Gap"}]}], "}"}], ",", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{"c1RWA", "[", "t0", "]"}], "/.", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Delta]", "->", "0"}], ",", 
              RowBox[{"\[CapitalOmega]", "->", "\[CapitalOmega]0"}]}], 
             "}"}]}], "]"}], "^", "2"}], ",", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"PrmSolnoRWA", "[", 
              RowBox[{"\[CapitalOmega]0", ",", "0"}], "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}], "[", "t0", "]"}], "]"}], "^", 
          "2"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[CapitalOmega]0", ",", "0", ",", 
         RowBox[{"\[CapitalOmega]max", "/", "\[Omega]Gap"}]}], "}"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"Placed", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\"\<RWA\>\"", ",", "\"\<no RWA\>\""}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Right", ",", "Bottom"}], "}"}]}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", 
        RowBox[{"Row", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<\[Omega]Gap = \>\"", ",", 
           RowBox[{"\[Omega]Gap", "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "Pi"}], ")"}]}], 
           ",", "\"\< \[Times] 2\[Pi] (t0 = \>\"", ",", " ", 
           RowBox[{"N", "[", "t0", "]"}], " ", ",", "\"\<)\>\""}], "}"}], 
         "]"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<\[CapitalOmega]0\>\"", ",", "None"}], "}"}]}]}], 
      "]"}]}], "]"}]}], ";"}]}], "Input",
