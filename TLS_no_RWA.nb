Cell[BoxData[{
 RowBox[{
  RowBox[{"c1RWA", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "t", "}"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"c1RWAraw", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c2RWA", "=", 
   RowBox[{"Function", "[", 
    RowBox[{
     RowBox[{"{", "t", "}"}], ",", 
     RowBox[{"Evaluate", "[", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{"c2RWAraw", "[", 
        RowBox[{"[", "2", "]"}], "]"}], "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalOmega]effrules", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"\[Delta]", "^", "2"}], "+", 
         RowBox[{"\[CapitalOmega]", "^", "2"}]}], "]"}], "->", 
       SubscriptBox["\[CapitalOmega]", "eff"]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Delta]", "^", "2"}], "+", 
        RowBox[{"\[CapitalOmega]", "^", "2"}]}], "->", 
       RowBox[{
        SubscriptBox["\[CapitalOmega]", "eff"], "^", "2"}]}], ",", 
      RowBox[{
       RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"\[Delta]", "^", "2"}], "+", 
          RowBox[{"\[CapitalOmega]", "^", "2"}]}], "]"}]}], "->", 
       RowBox[{"1", "/", 
        SubscriptBox["\[CapitalOmega]", "eff"]}]}]}], "}"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Just", " ", "for", " ", "the", " ", "TraditionalForm", " ", "below"}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.972871115566395*^9, 3.972871142112791*^9}, {
