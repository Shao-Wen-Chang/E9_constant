 CellLabel->"In[5]:=",ExpressionUUID->"bf257f49-8389-7f45-8bcd-a3d5c5ffb07a"],

Cell[BoxData[
 RowBox[{"DSolveValue", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{
        SuperscriptBox["c2", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}]}], "\[Equal]", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            FractionBox["\[CapitalOmega]", "2"], "+", 
            RowBox[{
             FractionBox["1", "2"], " ", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"2", " ", "\[ImaginaryI]", " ", "t", " ", 
               RowBox[{"(", 
                RowBox[{"1", "+", "\[Delta]"}], ")"}]}]], " ", 
             "\[CapitalOmega]"}]}], ")"}], " ", 
          RowBox[{"c1", "[", "t", "]"}]}], ")"}]}], "-", 
       RowBox[{"\[Delta]", " ", 
        RowBox[{"c2", "[", "t", "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{"\[ImaginaryI]", " ", 
       RowBox[{
        SuperscriptBox["c1", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}]}], "\[Equal]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          FractionBox["\[CapitalOmega]", "2"]}], "-", 
         RowBox[{
          FractionBox["1", "2"], " ", 
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "\[ImaginaryI]", " ", "t", " ", 
            RowBox[{"(", 
             RowBox[{"1", "+", "\[Delta]"}], ")"}]}]], " ", 
          "\[CapitalOmega]"}]}], ")"}], " ", 
       RowBox[{"c2", "[", "t", "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"c1", "[", "0", "]"}], "\[Equal]", "1"}], ",", 
     RowBox[{
      RowBox[{"c2", "[", "0", "]"}], "\[Equal]", "0"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"c1", ",", "c2"}], "}"}], ",", "t"}], "]"}]], "Output",
 Editable->False,
 CellChangeTimes->{3.9728711064227924`*^9, 3.9728715947339497`*^9, 
  3.9729886424142494`*^9, 3.97298876774938*^9, 3.9729892091834583`*^9, 
