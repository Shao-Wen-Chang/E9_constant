      RowBox[{"kx", "-", 
       RowBox[{"\[ImaginaryI]", " ", "ky"}]}], ")"}], " ", "d"}]}], "-", 
   RowBox[{
    FractionBox["3", "8"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"kx", "+", 
       RowBox[{"\[ImaginaryI]", " ", "ky"}]}], ")"}], "2"], " ", 
    SuperscriptBox["d", "2"]}], "+", 
