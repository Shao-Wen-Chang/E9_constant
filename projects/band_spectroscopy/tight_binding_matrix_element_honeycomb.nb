Cell[TextData[{
 "With the right unitary transformation W, the Hamiltonian can be made real, \
as expected from the C2T symmetry. Since C2 exchanges A and B sublattice, C2 \
is represented by ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "x"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8bae3d19-a6b4-804c-b101-3c5345682e3c"],
 ", and W is given by the Takagi factorization of ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Sigma]", "x"], TraditionalForm]],ExpressionUUID->
  "621546d2-3140-0b4a-b316-cf20afa6fce5"],
 "."
}], "Text",
 CellChangeTimes->{{3.980627731321308*^9, 3.980627757938162*^9}, {
  3.9806280466065063`*^9, 
  3.980628099477665*^9}},ExpressionUUID->"16bed4d0-55a6-604c-81d0-\
b30ec50f4170"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Wuni", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", "I"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"1", ",", 
        RowBox[{"-", "I"}]}], "}"}]}], "}"}], "/", 
    RowBox[{"Sqrt", "[", "2", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Table", "[", 
  RowBox[{
   RowBox[{"MatrixForm", "[", "W", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"W", ",", 
     RowBox[{"{", 
      RowBox[{"Wuni", ",", 
       RowBox[{"Wuni", "\[ConjugateTranspose]"}]}], "}"}]}], "}"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"MatrixForm", "[", 
  RowBox[{"ComplexExpand", "[", 
   RowBox[{
    RowBox[{"Wuni", "\[ConjugateTranspose]"}], ".", "HhexIIkxy", ".", 
    "Wuni"}], "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MatrixForm", "[", 
   RowBox[{"Wuni", ".", 
    RowBox[{"Wuni", "\[Transpose]"}]}], "]"}], 
  RowBox[{"(*", 
   RowBox[{"This", " ", "should", " ", "be", " ", 
    SubscriptBox["\[Sigma]", "x"]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9806275863419247`*^9, 3.9806276939070396`*^9}, {
