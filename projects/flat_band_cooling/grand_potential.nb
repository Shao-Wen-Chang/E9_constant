      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[CapitalLambda]", ">", "0"}], ",", 
        RowBox[{"\[Beta]", ">", "0"}]}], "}"}]}]}], "]"}], 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "So", " ", "we", " ", "see", " ", "that", " ", "the", " ", "\[Mu]"}], "=", 
     RowBox[{
