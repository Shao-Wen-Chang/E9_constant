Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalDelta]PL", "=", 
   RowBox[{
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "b"}], "*", 
        RowBox[{"(", 
         RowBox[{"x", "-", "u"}], ")"}]}], "]"}]}], "]"}], "-", 
    RowBox[{"PolyLog", "[", 
     RowBox[{"2", ",", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "b"}], "*", "x"}], "]"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"\[CapitalDelta]PL", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"b", "->", "1"}], ",", 
      RowBox[{"u", "->", "1"}]}], "}"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "0", ",", "10"}], "}"}]}], "]"}]}], "Input",
