         RowBox[{"(", 
          RowBox[{"x", "-", "\[Mu]"}], ")"}]}], "]"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "\[CapitalLambda]"}], ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[CapitalLambda]", ">", "0"}], ",", 
        RowBox[{"\[Mu]", "\[Element]", "Reals"}], ",", 
        RowBox[{"\[Beta]", ">", "0"}]}], "}"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Gsys0", "=", 
