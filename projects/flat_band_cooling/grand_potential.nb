Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Integrate", "[", 
  RowBox[{
   RowBox[{"Log", "[", 
    RowBox[{"1", "+", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", "x"}], "]"}]}], "]"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.9850059650746174`*^9, 3.985005994077692*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"10dbfe69-7a12-824a-af84-dd7227cf96a4"],

Cell[BoxData[
 RowBox[{"PolyLog", "[", 
  RowBox[{"2", ",", 
   RowBox[{"-", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"-", "x"}]]}]}], "]"}]], "Output",
 CellChangeTimes->{3.985013387868891*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"2e0157d9-c77d-6544-bc6c-9dc63bcb8b37"]
}, Open  ]],

